@model dynamic

@{
    ViewBag.Title = "title";
    Layout = "_Layout";
}

<section class="page">

    <h1 class="page-title">Meus Projetos</h1>

    <div class="cards-container">

        <div class="custom-card">

            <h3>Sistema de Galeria</h3>

            <p>
                Projeto desenvolvido em ASP.NET MVC utilizando
                Entity Framework e autenticação.
            </p>

            <a class="btn btn-primary" href="#">
                Ver Projeto
            </a>

        </div>

        <div class="custom-card">

            <h3>Controle de Produtos</h3>

            <p>
                Sistema CRUD para gerenciamento de produtos
                e controle de validade.
            </p>

            <a class="btn btn-primary" href="#">
                Ver Projeto
            </a>

        </div>

        <div class="custom-card">

            <h3>App de Notas</h3>

            <p>
                Aplicativo mobile criado com React Native e Expo.
            </p>

            <a class="btn btn-primary" href="#">
                Ver Projeto
            </a>

        </div>

    </div>

</section>