@model dynamic

@{
    ViewBag.Title = "Projetos";
    Layout = "_Layout";
}

<section class="page">
    <h1 class="page-title">Meus Projetos</h1>

    <div class="cards-container">

        <div class="custom-card">
            <h3>Catálogo de Doces</h3>
            <p>
                Aplicação desenvolvida em C# para exibição e gerenciamento de um catálogo de doces.
            </p>
            <a class="btn btn-primary"
               href="https://github.com/botinho12/Catalogo_De_Doces"
               target="_blank">
                Ver Projeto
            </a>
        </div>

        <div class="custom-card">
            <h3>CineFilms</h3>
            <p>
                Sistema desenvolvido em TypeScript para consulta e gerenciamento de filmes.
            </p>
            <a class="btn btn-primary"
               href="https://github.com/botinho12/CineFilms"
               target="_blank">
                Ver Projeto
            </a>
        </div>

        <div class="custom-card">
            <h3>MinhaApi</h3>
            <p>
                API REST desenvolvida em C# utilizando ASP.NET para gerenciamento de dados.
            </p>
            <a class="btn btn-primary"
               href="https://github.com/botinho12/MinhaAPI"
               target="_blank">
                Ver Projeto
            </a>
        </div>

    </div>
</section>