@model dynamic

@{
    ViewBag.Title = "Cursos e Conhecimentos";
    Layout = "_Layout";
}

<section class="page">

    <h1 class="page-title">Formação e Cursos</h1>

    <div class="cards-container">

        <div class="custom-card">
            <h3>Técnico em Desenvolvimento de Sistemas</h3>
            <p>
                Formação técnica realizada em Barra Bonita - SP, com duração de
                1 ano e meio, abrangendo lógica de programação, banco de dados,
                desenvolvimento web e análise de sistemas.
            </p>
        </div>

        <div class="custom-card">
            <h3>Gestão da Tecnologia da Informação - FATEC Jaú</h3>
            <p>
                Graduação em andamento voltada para gestão de projetos,
                infraestrutura de TI, banco de dados, engenharia de software
                e desenvolvimento de soluções tecnológicas.
            </p>
        </div>

        <div class="custom-card">
            <h3>C# Completo - Programação Orientada a Objetos + Projetos</h3>
            <p>
                Curso realizado pela Udemy com foco em orientação a objetos,
                coleções, LINQ, Entity Framework, tratamento de exceções e
                desenvolvimento de aplicações práticas em C#.
            </p>
        </div>

        <div class="custom-card">
            <h3>Web API .NET Core Essencial (.NET 8 / .NET 9)</h3>
            <p>
                Desenvolvimento de APIs REST utilizando ASP.NET Core,
                Entity Framework Core, autenticação, Swagger e arquitetura
                em camadas seguindo boas práticas de mercado.
            </p>
        </div>

        <div class="custom-card">
            <h3>.NET Core - Curso Orientado para o Mercado de Trabalho</h3>
            <p>
                Curso em andamento com foco na criação de APIs completas
                utilizando DDD, SOLID, testes automatizados, Docker,
                Azure DevOps, CI/CD, deploy no Azure e integração com IA.
            </p>
        </div>

    </div>

    <h2 class="page-title" style="margin-top:40px;">
        Tecnologias e Ferramentas
    </h2>

    <div class="custom-card">

        <p>
            <strong>Linguagens:</strong>
            C#, JavaScript e TypeScript.
        </p>

        <p>
            <strong>Back-end:</strong>
            ASP.NET Core MVC, ASP.NET Web API, Entity Framework Core e JWT.
        </p>

        <p>
            <strong>Banco de Dados:</strong>
            SQL Server.
        </p>

        <p>
            <strong>Front-end:</strong>
            HTML5, CSS3, Bootstrap e Razor Views.
        </p>

        <p>
            <strong>Mobile:</strong>
            React Native e Expo.
        </p>

        <p>
            <strong>Ferramentas:</strong>
            Git, GitHub, Docker, Azure DevOps, Visual Studio e Rider.
        </p>

    </div>

</section>